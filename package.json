{
  "name": "transform-design-system",
  "version": "1.0.0",
  "description": "Design system for TransformSEO — tokens, shadcn/ui components, Tailwind config",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
